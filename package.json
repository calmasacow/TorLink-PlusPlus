{
  "name": "torlink-plusplus",
  "version": "1.1.1",
  "description": "TorLink++: Torlink with a Torznab/Radarr/Sonarr web gateway and embedded browser TUI.",
  "type": "module",
  "packageManager": "pnpm@10.34.4",
  "bin": {
    "torlnk": "./dist/cli.cjs"
  },
  "files": [
    "dist",
    "preview"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx src/index.tsx",
    "build": "tsup",
    "postbuild": "cp scripts/cli-entry.cjs dist/cli.cjs && chmod +x dist/cli.cjs",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "verify:seeding": "tsx scripts/verify-seeding.ts",
    "previews": "tsx scripts/render-previews.tsx",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "torrent",
    "torrent-client",
    "torrent-search",
    "downloader",
    "magnet",
    "magnet-links",
    "p2p",
    "webtorrent",
    "seeding",
    "tui",
    "terminal",
    "cli",
    "ink",
    "zero-configuration",
    "zero-setup",
    "fitgirl"
  ],
  "author": "bairon (original Torlink); TorLink++ fork by calmasacow",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/calmasacow/TorLink-PlusPlus.git"
  },
  "homepage": "https://github.com/calmasacow/TorLink-PlusPlus#readme",
  "bugs": {
    "url": "https://github.com/calmasacow/TorLink-PlusPlus/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "env-paths": "^4.0.0",
    "ink": "^7.0.5",
    "node-pty": "^1.1.0",
    "parse-torrent": "^11.0.21",
    "react": "^19.2.7",
    "webtorrent": "^2.4.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/ws": "^8.18.1",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
